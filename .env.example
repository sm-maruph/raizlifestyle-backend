# Server
PORT=5000
NODE_ENV=development
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=https://rainzlifestyleofficial.onrender.com,https://www.rainzlifestyle.com,https://rainzlifestyle.com,http://localhost:3000
# Supabase — from Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SERVER ONLY — never ship to frontend
SUPABASE_JWT_SECRET=your-jwt-secret               # Settings → API → JWT Settings
